{
    "id": "com.mattermost.google-meet",
    "name": "Google Meet",
    "description": "Start and join Google Meet meetings from Mattermost.",
    "homepage_url": "https://github.com/mattermost/mattermost-plugin-meet",
    "support_url": "https://github.com/mattermost/mattermost-plugin-meet/issues",
    "icon_path": "assets/icon.svg",
    "min_server_version": "6.2.1",
    "server": {
        "executables": {
            "linux-amd64": "server/dist/plugin-linux-amd64",
            "linux-arm64": "server/dist/plugin-linux-arm64",
            "darwin-amd64": "server/dist/plugin-darwin-amd64",
            "darwin-arm64": "server/dist/plugin-darwin-arm64",
            "windows-amd64": "server/dist/plugin-windows-amd64.exe"
        }
    },
    "webapp": {
        "bundle_path": "webapp/dist/main.js"
    },
    "settings_schema": {
        "header": "Configure the Google Meet plugin. You need to create a Google OAuth 2.0 Client ID in the [Google Cloud Console](https://console.cloud.google.com/apis/credentials). The redirect URI will be shown here once the plugin is activated.",
        "footer": "",
        "settings": [
            {
                "key": "GoogleClientID",
                "display_name": "Google OAuth Client ID",
                "type": "text",
                "help_text": "The Client ID from your Google OAuth 2.0 credentials.",
                "default": ""
            },
            {
                "key": "GoogleClientSecret",
                "display_name": "Google OAuth Client Secret",
                "type": "text",
                "help_text": "The Client Secret from your Google OAuth 2.0 credentials.",
                "default": ""
            },
            {
                "key": "EncryptionKey",
                "display_name": "Encryption Key",
                "type": "generated",
                "help_text": "A secret key used to encrypt OAuth tokens stored in the database. Regenerating this key will invalidate all existing user connections.",
                "default": ""
            }
        ]
    }
}
